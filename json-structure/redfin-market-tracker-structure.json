{
  "title": "Redfin Market Tracker Record Structure",
  "description": "JSON structure documentation for a Redfin Data Center market tracker record, representing housing market metrics for a region and time period.",
  "type": "object",
  "fields": [
    { "name": "period_begin", "type": "string", "format": "date", "required": true, "description": "Start date of the measurement period." },
    { "name": "period_end", "type": "string", "format": "date", "required": true, "description": "End date of the measurement period." },
    { "name": "period_duration", "type": "string", "required": false, "description": "Period type (weekly, monthly).", "enum": ["weekly", "monthly"] },
    { "name": "region_type", "type": "string", "required": true, "description": "Geographic level.", "enum": ["national", "metro", "state", "county", "city", "zip_code", "neighborhood"] },
    { "name": "region", "type": "string", "required": true, "description": "Name of the geographic region." },
    { "name": "city", "type": "string", "required": false, "description": "City name if applicable." },
    { "name": "state", "type": "string", "required": false, "description": "State name." },
    { "name": "state_code", "type": "string", "required": false, "description": "Two-letter state code." },
    { "name": "property_type", "type": "string", "required": false, "description": "Property type segment.", "enum": ["All Residential", "Single Family Residential", "Condo/Co-op", "Townhouse", "Multi-Family"] },
    { "name": "is_seasonally_adjusted", "type": "boolean", "required": false, "description": "Whether seasonally adjusted." },
    { "name": "median_sale_price", "type": "number", "required": false, "description": "Median sale price in USD." },
    { "name": "median_sale_price_yoy", "type": "number", "required": false, "description": "YoY change as decimal." },
    { "name": "median_list_price", "type": "number", "required": false, "description": "Median list price in USD." },
    { "name": "median_ppsf", "type": "number", "required": false, "description": "Median price per square foot in USD." },
    { "name": "homes_sold", "type": "integer", "required": false, "description": "Number of homes sold." },
    { "name": "homes_sold_yoy", "type": "number", "required": false, "description": "YoY change in homes sold." },
    { "name": "pending_sales", "type": "integer", "required": false, "description": "Number of pending sales." },
    { "name": "new_listings", "type": "integer", "required": false, "description": "Number of new listings." },
    { "name": "inventory", "type": "integer", "required": false, "description": "Active inventory count." },
    { "name": "months_of_supply", "type": "number", "required": false, "description": "Months of supply." },
    { "name": "median_dom", "type": "integer", "required": false, "description": "Median days on market." },
    { "name": "avg_sale_to_list", "type": "number", "required": false, "description": "Average sale-to-list ratio." },
    { "name": "sold_above_list", "type": "number", "required": false, "description": "Proportion sold above list price." },
    { "name": "price_drops", "type": "number", "required": false, "description": "Proportion with price drops." },
    { "name": "off_market_in_two_weeks", "type": "number", "required": false, "description": "Proportion going off market within 2 weeks." }
  ]
}
